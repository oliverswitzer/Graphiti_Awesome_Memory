app:
  project_name: graphiti-memory
  environment: development
  base_url: http://your-pc-hostname:8001
  admin_frontend_url: http://your-pc-hostname:3000

neo4j:
  uri: bolt://neo4j:7687
  user: neo4j
  password: CHANGE_ME
  http_port: 7474
  bolt_port: 7687

redis:
  url: redis://redis:6379/0

llm:
  base_url: https://api.openai.com/v1
  api_key: sk-YOUR_OPENAI_KEY
  model: gpt-4.1

llm_fast:
  base_url: https://api.openai.com/v1
  api_key: sk-YOUR_OPENAI_KEY
  model: gpt-4.1-mini

embeddings:
  base_url: https://api.openai.com/v1
  api_key: sk-YOUR_OPENAI_KEY
  model: text-embedding-3-small

reranker:
  base_url: https://api.openai.com/v1
  api_key: sk-YOUR_OPENAI_KEY
  model: reranker-001

adapter:
  host: 0.0.0.0
  port: 8000
  api_key: CHANGE_ME
  jwt_secret: CHANGE_ME
  allowed_origins:
    - http://localhost:3000

frontend:
  port: 3000

worker:
  concurrency: 4

security:
  admin_username: admin
  admin_password: CHANGE_ME
  jwt_expiry_seconds: 3600

logging:
  level: INFO

docker:
  neo4j_image: neo4j:5.26.0
  adapter_image: graphiti-adapter:latest
  frontend_image: graphiti-admin:latest
